# Supabase Configuration
# Get these values from: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only — NEVER expose to the client)
# Used by admin API routes (/api/admin/*) to bypass RLS safely.
# Get from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJpcnlxbWt2cmt1eGhwaHZoaHhzIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NjgwOTg5NywiZXhwIjoyMDkyMzg1ODk3fQ.z3VNYsHoF0lXis5GJS935Zwfz0Eo6xbsMmbwB1zndhwupdate

# Groq API Key (server-side only — NEVER expose to the client)
# Used by /api/transcribe for Whisper AI speech-to-text transcription.
# Get a free key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Site URL (localhost for development)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# PostHog Analytics
# Get your project API key from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Upstash Redis — Rate Limiting (optional but recommended for production)
# Without these, rate limiting is disabled and all requests pass through.
# Create a free Redis database at: https://console.upstash.com/
# Then copy the REST URL and token from the database dashboard.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Sentry — Error Monitoring
# Create a project at https://sentry.io and copy the DSN from Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/project-id
# Optional: source map upload (only needed if you run sentry-cli in CI)
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
SENTRY_AUTH_TOKEN=your-auth-token
